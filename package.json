{
  "name": "even-pomodoro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "qr": "evenhub qr --http --port 5173",
    "pack": "npm run build && evenhub pack app.json dist -o out.ehpk",
    "run-simulator": "npx @evenrealities/evenhub-simulator@latest -b default http://localhost:5173",
    "start": "npm run qr & npm run dev & npm run run-simulator"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.9",
    "@evenrealities/evenhub-simulator": "^0.6.2",
    "@jappyjan/even-better-sdk": "^0.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "even-toolkit": "^1.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.2.4",
    "react-router": "^7.0.0",
    "tailwind-merge": "^2.2.0",
    "upng-js": "^2.1.0"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.11",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.4.0",
    "vite": "^5.4.0"
  }
}
